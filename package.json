{
  "name": "trap-card-game",
  "private": true,
  "version": "0.1.0",
  "description": "Trap Card Game - Expo + Cloudflare PartyServer multiplayer card game",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace=@trap/shared",
    "test": "npm run test --workspaces --if-present",
    "test:shared": "npm run test --workspace=@trap/shared",
    "test:party": "npm run test --workspace=@trap/party",
    "test:e2e": "npm run test:e2e --workspace=@trap/mobile",
    "e2e:clean": "npm run e2e:clean --workspace=@trap/mobile"
  },
  "engines": {
    "node": ">=24"
  }
}
