{
  "expo": {
    "name": "Trap Card Game",
    "slug": "trap-card-game",
    "scheme": "trapcard",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trapcard.app"
    },
    "android": {
      "package": "com.trapcard.app",
      "googleServicesFile": "./google-services.json"

    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1bd3cf8b-7413-4f27-9322-7b8637b6c2d3"
      }
    },
    "owner": "hrmnfng"
  }
}
