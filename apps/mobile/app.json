{
  "expo": {
    "name": "Trap Card Game",
    "slug": "trap-card-game",
    "scheme": "trapcard",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./public/icons/icon-1024.png",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trapcard.app"
    },
    "android": {
      "package": "com.trapcard.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-notifications"]
  }
}
