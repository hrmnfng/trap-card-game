{
  "name": "@trap/mobile",
  "version": "0.1.0",
  "description": "Expo (React Native) client for Trap Card Game",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@trap/shared": "*",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-device": "~7.0.0",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "moti": "^0.30.0",
    "partysocket": "^1.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^24.12.2",
    "@types/react": "~18.3.12",
    "typescript": "^5.6.0",
    "vitest": "3.1.4"
  }
}
