{
  "name": "@trap/party",
  "version": "0.1.0",
  "description": "Cloudflare Worker + PartyServer Durable Object for Trap Card Game",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:apply:local": "wrangler d1 execute trapcard --local --file=./src/db/schema.sql",
    "db:apply:remote": "wrangler d1 execute trapcard --remote --file=./src/db/schema.sql",
    "reset-password": "node --disable-warning=ExperimentalWarning scripts/reset-password.ts"
  },
  "dependencies": {
    "@trap/shared": "*",
    "partyserver": "^0.5.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.12.21",
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.0",
    "vitest": "3.2.6",
    "wrangler": "^4.98.0"
  }
}
