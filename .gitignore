# Environment files — never commit any of these. Client config (EXPO_PUBLIC_*)
# lives in a local .env / .env.local for dev; production builds inject it via
# EAS env / GitHub Actions Secrets (no .env.production in the repo).
.env
.env.*

# Docker
docker-compose.override.yml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Firebase
*-firebase-adminsdk-*.json
firebase-credentials.json
# Android client config — CI materializes it from the GOOGLE_SERVICES_JSON
# GitHub secret (release.yml); keep a local copy for manual builds. If you
# change ignores here, mirror them in .easignore (which must NOT ignore this
# file, or EAS uploads would drop it).
apps/mobile/google-services.json

# Node / workspaces
node_modules/
dist/
# ...but keep apps/mobile/dist present (empty) so wrangler's [assets] block
# works before an export exists. Contents stay ignored.
!apps/mobile/dist/
apps/mobile/dist/*
!apps/mobile/dist/.gitkeep
*.tsbuildinfo

# Cloudflare
.wrangler/
.dev.vars

# Expo
.expo/
web-build/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Superpowers brainstorming companion
.superpowers/
